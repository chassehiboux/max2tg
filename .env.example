# Max credentials (DevTools → Application → Local Storage → web.max.ru)
MAX_TOKEN=your___oneme_auth_value
MAX_DEVICE_ID=your___oneme_device_id_value
# (Optional) Max chat IDs to listen, comma-separated. Leave unset to listen to all chats.
# MAX_CHAT_IDS=-123,-456
# (Optional) Max chat IDs to exclude from forwarding, comma-separated.
# MAX_EXCLUDE_CHAT_IDS=-789,-999

# Telegram (get token from @BotFather; find your chat_id via @userinfobot)
TG_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TG_CHAT_ID=123456789

# (Optional) SOCKS5 proxy for Telegram (e.g. socks5://user:pass@host:port)
TG_PROXY=socks5://188.253.23.149:3129

# Debug mode: verbose logs + JSON dump to debug/ (true/false)
DEBUG=false

# Allow replies from Telegram back to Max (true/false)
REPLY_ENABLED=false
